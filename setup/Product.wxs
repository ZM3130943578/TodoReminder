<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="TodoReminder"
    Manufacturer="TodoReminder"
    Version="1.0.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="appIcon" SourceFile="src\TodoReminder.App\TodoReminder.ico" />
    <Property Id="ARPPRODUCTICON" Value="appIcon" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="APPLICATIONROOT" Name="TodoReminder">
        <Component Id="MainExecutable" Guid="*">
          <File Id="TodoReminderExe" Name="TodoReminder.App.exe"
                Source="src\TodoReminder.App\bin\Release\net10.0-windows\win-x64\publish\TodoReminder.App.exe"
                KeyPath="yes">
            <Shortcut Id="StartMenuShortcut"
                      Directory="ProgramMenuFolder"
                      Name="TodoReminder"
                      WorkingDirectory="APPLICATIONROOT"
                      Icon="appIcon" />
            <Shortcut Id="DesktopShortcut"
                      Directory="DesktopFolder"
                      Name="TodoReminder"
                      WorkingDirectory="APPLICATIONROOT"
                      Icon="appIcon" />
          </File>
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuFolder" Guid="*">
        <RemoveFolder Id="RemoveStartMenuFolder" Directory="ProgramMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\TodoReminder" Name="installed" Type="integer" Value="1" />
      </Component>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopFolderComponent" Guid="*">
        <RegistryValue Root="HKCU" Key="Software\TodoReminder" Name="desktop" Type="integer" Value="1" />
      </Component>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="TodoReminder" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuFolder" />
      <ComponentRef Id="DesktopFolderComponent" />
    </Feature>
  </Package>
</Wix>
