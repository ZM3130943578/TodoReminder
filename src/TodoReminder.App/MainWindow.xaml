<Window x:Class="TodoReminder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoReminder.App.ViewModels"
        Title="TodoReminder" Icon="TodoReminder.ico" Height="640" Width="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="今日待办"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="⚙"
                    Command="{Binding OpenSettingsCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="18"
                    Padding="8,4"
                    Cursor="Hand"
                    ToolTip="设置"/>
        </Grid>

        <Separator Grid.Row="0" VerticalAlignment="Bottom" Opacity="0.3"/>

        <!-- Row 1: Date Navigation -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀"
                    Command="{Binding GoToPreviousDayCommand}"
                    Background="Transparent" BorderThickness="0"
                    FontSize="14" Padding="6,4" Cursor="Hand"
                    ToolTip="上一天"/>
            <Button Grid.Column="1" Content="今天"
                    Command="{Binding GoToTodayCommand}"
                    Background="Transparent" BorderThickness="0"
                    FontSize="13" Padding="8,4" Cursor="Hand" Margin="4,0"/>
            <Button Grid.Column="2" Content="▶"
                    Command="{Binding GoToNextDayCommand}"
                    Background="Transparent" BorderThickness="0"
                    FontSize="14" Padding="6,4" Cursor="Hand"
                    ToolTip="下一天"/>
            <TextBlock Grid.Column="3" Text="{Binding DateDisplay}"
                       FontSize="14" Foreground="#666"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <Separator Grid.Row="1" VerticalAlignment="Bottom" Opacity="0.3"/>

        <!-- Row 2: Add Button -->
        <Button Grid.Row="2" Content="+ 新增事项"
                Command="{Binding AddNewTodoCommand}"
                Background="Transparent" BorderThickness="1" BorderBrush="#CCC"
                FontSize="14" Padding="12,8" Cursor="Hand"
                HorizontalContentAlignment="Left" Margin="0,4,0,8"/>

        <!-- Row 3: Todo List -->
        <ListBox Grid.Row="3"
                 ItemsSource="{Binding TodoItems}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TodoItemViewModel}">
                    <Border Padding="8,6" Margin="0,2">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status Icon -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding StatusIcon}"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <!-- Due Time -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DueTimeDisplay}"
                                           FontSize="14" Foreground="#888"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DueTimeDisplay}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Title -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextDecorations" Value="None"/>
                                            <Setter Property="Opacity" Value="1.0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Abandoned">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Edit Button -->
                                <Button Grid.Column="3" Content="✎"
                                        Command="{Binding EditCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Padding="4,2" Cursor="Hand"
                                        ToolTip="编辑" Margin="2,0"/>

                                <!-- Complete Button -->
                                <Button Grid.Column="4" Content="✓"
                                        Command="{Binding ToggleCompleteCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Padding="4,2" Cursor="Hand"
                                        ToolTip="标记完成/恢复" Margin="2,0"/>

                                <!-- Abandon Button -->
                                <Button Grid.Column="5" Content="⊘"
                                        Command="{Binding ToggleAbandonCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Padding="4,2" Cursor="Hand"
                                        ToolTip="标记废弃/恢复" Margin="2,0"/>

                                <!-- Delete Button -->
                                <Button Grid.Column="6" Content="✕"
                                        Command="{Binding DeleteCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Padding="4,2" Cursor="Hand"
                                        ToolTip="删除" Foreground="#C44"/>
                            </Grid>

                            <!-- Note -->
                            <TextBlock Text="{Binding Note}"
                                       FontSize="12" Foreground="#999"
                                       Margin="24,2,0,0"
                                       TextWrapping="Wrap"
                                       MaxHeight="40">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Note}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Note}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Separator Grid.Row="3" VerticalAlignment="Bottom" Opacity="0.3"/>

        <!-- Row 4: Stats Footer -->
        <Border Grid.Row="4" Padding="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock FontSize="13" Foreground="#888">
                    <Run Text="待处理 "/>
                    <Run Text="{Binding PendingCount, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#888" Margin="12,0,0,0">
                    <Run Text="已完成 "/>
                    <Run Text="{Binding CompletedCount, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#888" Margin="12,0,0,0">
                    <Run Text="已废弃 "/>
                    <Run Text="{Binding AbandonedCount, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>
        </Border>


    </Grid>
</Window>
