<Window x:Class="TodoReminder.App.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug 调试面板" Width="400" Height="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="调试工具" FontSize="18" FontWeight="SemiBold"
                   Foreground="#D35400" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1">
            <Button Content="立即检查事项提醒" Height="36" FontSize="14" Margin="0,0,0,6"
                    Click="OnCheckReminders"/>
            <Button Content="立即检查定时弹出" Height="36" FontSize="14" Margin="0,0,0,6"
                    Click="OnCheckSchedules"/>
            <Button Content="立即执行今日继承" Height="36" FontSize="14" Margin="0,0,0,6"
                    Click="OnRollover"/>
            <Button Content="打开数据库目录" Height="36" FontSize="14" Margin="0,0,0,6"
                    Click="OnOpenDbFolder"/>
            <Separator Margin="0,4"/>
            <Button Content="⚠ 清空所有待办数据" Height="36" FontSize="14" Margin="0,4,0,0"
                    Foreground="White" Background="#C0392B"
                    Click="OnClearData"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
