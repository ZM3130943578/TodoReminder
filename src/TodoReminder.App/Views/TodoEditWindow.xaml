<Window x:Class="TodoReminder.App.Views.TodoEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增事项" Height="Auto" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        SizeToContent="Height">
    <StackPanel Margin="16">
        <TextBlock Text="标题" FontSize="13" Margin="0,0,0,4"/>
        <TextBox x:Name="TitleBox" FontSize="14" Height="30" Margin="0,0,0,8"/>
        <TextBlock Text="备注" FontSize="13" Margin="0,0,0,4"/>
        <TextBox x:Name="NoteBox" FontSize="14" Height="60"
                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>
        <TextBlock Text="提醒时间" FontSize="13" Margin="0,0,0,4"/>
        <WrapPanel Margin="0,0,0,8">
            <CheckBox x:Name="TimeEnabledCheck" Content="启用" VerticalAlignment="Center" Margin="0,0,8,0" Checked="OnTimeEnabledChanged" Unchecked="OnTimeEnabledChanged"/>
            <ComboBox x:Name="HourCombo" Width="60" Height="30" IsEnabled="False"/>
            <TextBlock Text=" : " FontSize="14" VerticalAlignment="Center"/>
            <ComboBox x:Name="MinuteCombo" Width="60" Height="30" IsEnabled="False"/>
        </WrapPanel>
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="取消"
                    IsCancel="True" Width="80" Height="32"
                    Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="确认"
                    Click="OnConfirm" Width="80" Height="32"
                    IsDefault="True"/>
        </Grid>
    </StackPanel>
</Window>
