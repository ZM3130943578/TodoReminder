<Window x:Class="TodoReminder.App.Views.ReminderPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="待办提醒" Width="340" Height="Auto"
        SizeToContent="Height" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize">
    <Border Padding="16" Background="#FFF8F0">
        <StackPanel>
            <TextBlock Text="⏰ 待办提醒" FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,12" Foreground="#D35400"/>

            <TextBlock x:Name="TimeText" FontSize="14" Foreground="#888" Margin="0,0,0,4"/>
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                       TextWrapping="Wrap" Margin="0,0,0,4"/>
            <TextBlock x:Name="NoteText" FontSize="13" Foreground="#666"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="知道了"
                        Click="OnDismiss" FontSize="13" Height="32" Margin="0,0,4,4"/>
                <Button Grid.Row="0" Grid.Column="1" Content="10分钟后"
                        Click="OnSnooze10" FontSize="13" Height="32" Margin="4,0,4,4"/>
                <Button Grid.Row="0" Grid.Column="2" Content="30分钟后"
                        Click="OnSnooze30" FontSize="13" Height="32" Margin="4,0,0,4"/>
                <Button Grid.Row="1" Grid.Column="0" Content="标记完成"
                        Click="OnComplete" FontSize="13" Height="32" Margin="0,4,4,0"/>
                <Button Grid.Row="1" Grid.Column="1" Content="废弃"
                        Click="OnAbandon" FontSize="13" Height="32" Margin="4,4,4,0"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
