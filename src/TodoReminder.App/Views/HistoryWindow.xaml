<Window x:Class="TodoReminder.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录" Icon="/TodoReminder.ico" Height="480" Width="520"
        WindowStartupLocation="CenterOwner"
        MinHeight="320" MinWidth="400">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="历史完成任务" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ListView Grid.Row="1" ItemsSource="{Binding}"
                  BorderThickness="0" Background="Transparent"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" Margin="0,2">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding StatusDisplay}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Foreground="#888"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding StatusTimeDisplay}"
                                           FontSize="12" Foreground="#999"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>

                            <Grid Margin="24,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="11" Foreground="#AAA"
                                           VerticalAlignment="Center">
                        <Run Text="日期: "/>
                        <Run Text="{Binding RecordDateDisplay}"/>
                    </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Note}"
                                           FontSize="11" Foreground="#AAA"
                                           Margin="12,0,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Note}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Note}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
