<Window x:Class="TodoReminder.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录" Icon="/TodoReminder.ico" Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        MinHeight="400" MinWidth="450">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="历史记录" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="从" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <DatePicker x:Name="FromDatePicker" Width="110" Height="28" Margin="0,0,8,0"/>
            <TextBlock Text="到" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <DatePicker x:Name="ToDatePicker" Width="110" Height="28" Margin="0,0,8,0"/>
            <Button Content="查询" Width="60" Height="28" Click="OnSearch" Margin="0,0,4,0"/>
            <Button Content="全部" Width="60" Height="28" Click="OnShowAll"/>
        </WrapPanel>

        <ListView Grid.Row="2" x:Name="HistoryList"
                  BorderThickness="0" Background="Transparent"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" Margin="0,2">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding StatusDisplay}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Foreground="#888"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding StatusTimeDisplay}"
                                           FontSize="12" Foreground="#999"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>

                            <Grid Margin="24,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock FontSize="11" Foreground="#AAA" Text="创建 "/>
                                    <TextBlock FontSize="11" Foreground="#AAA" Text="{Binding CreatedAtDisplay, Mode=OneWay}"/>
                                    <TextBlock FontSize="11" Foreground="#AAA" Text="  │  "/>
                                    <TextBlock FontSize="11" Foreground="#AAA" Text="{Binding StatusLabel, Mode=OneWay}"/>
                                    <TextBlock FontSize="11" Foreground="#AAA" Text=" "/>
                                    <TextBlock FontSize="11" Foreground="#AAA" Text="{Binding StatusTimeDisplay, Mode=OneWay}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="24,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="11" Foreground="#AAA"
                                           VerticalAlignment="Center">
                                    <Run Text="任务日期 "/>
                                    <Run Text="{Binding RecordDateDisplay, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Note}"
                                           FontSize="11" Foreground="#AAA"
                                           Margin="12,0,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Note}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Note}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="3" FontSize="12" Foreground="#999" Margin="0,8,0,0">
            <Run Text="共 "/>
            <Run x:Name="CountText" Text="0"/>
            <Run Text=" 条记录"/>
        </TextBlock>
    </Grid>
</Window>
